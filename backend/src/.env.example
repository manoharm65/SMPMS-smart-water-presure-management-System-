# MongoDB connection string (you will provide this)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# JWT signing secret (set to a long random string)
JWT_SECRET=change-me-super-long-random-string
JWT_EXPIRES_IN=7d

# Default admin user (auto-upserted on server start)
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=admin@123

# API port
PORT=8080

# Optional: CORS allowlist (comma-separated). Leave empty to allow all in dev.
# CORS_ORIGIN=http://localhost:5173
